      "id": 1,
      "title": "Indoor Temperature",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 18 },
              { "color": "orange", "value": 24 },
              { "color": "red", "value": 28 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "" },
          "query": "from(bucket: \"sensors\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"indoor_climate\")\n  |> filter(fn: (r) => r._field == \"temperature\")\n  |> last()"
        }
      ],
      "datasource": { "type": "influxdb" }
